#include<iostream>
using namespace std ;
int main(){
    int r;
    cout <<"enter the rows of the pyramid ";
    cin >> r ;
    for (int i=1;i<=r;++i){
        //tp print space we are using this loop
        for( int  j=1;j<=r-i;++j){
            cout << " ";
        }
        for(int k=1;k<=(2*i-1);++k){
            cout <<"*";
        }
        cout << endl ;

    }
}
