// to check if a string is palindrome or not 
#include<iostream>
using namespace std ;
bool ispalindrome(string s){
    int n = s.length();
    for(int i=0;i<n/2;i++){
        if(s[i]!=s[n-1-i]){
            return false;
        }
    }
    return true ;
}
int main(){
    string str;
    cout << "enter a string:";
    cin >> str;
    if(ispalindrome(str)){
        cout << "the string is palindrome";
    }
    else{
        cout << "the string is not palindrome ";
    }
    }
    

