// calculate cahrecter frequency
#include<iostream>
using namespace std ;
int main(){
    cout << "enter the string";
    string str ;
    cin >> str ;
    int hash[256]={0};
    for(int i=0;i<str.length();i++){
        hash[int(str[i])]++;
    }
    char q;
    cout << "enter the letter whose frequency you want";
    cin >> q;
    cout << hash[str[int( q )]];
}
