// calculate cahrecter frequency
#include<iostream>
using namespace std ;
int main(){
    cout << "enter the string";
    string str ;
    cin >> str ;
    int hash[256]={0};
    for(int i=0;i<str.length();i++){
        hash[int(str[i])]++;
    }
    cout << " enter  the charecter whose freq you want ";
    char  q;
    cin >> q;
    cout << "frequency of" << q << " is : " << hash[int(q)];
    
}
