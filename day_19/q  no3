// program for transpose of a matrix 
#include<iostream>
using namespace std ;
int main (){
    int row , col;
    cout << "enter the no of rows and columns ";
    cin >> row >> col ;
    int a[row][col];
    cout << " enter the elements of the matrix";
    for(int i=0;i<row;i++){
        for(int j=0;j<col;j++){
            cin >> a[i][j];
        }
    }
    cout << "transpose of the matrix is :";
    for(int i=0;i<row;i++){
        for(int j=0;j<col;j++){
            cout <<a[j][i]; " "
        }
    }
}
