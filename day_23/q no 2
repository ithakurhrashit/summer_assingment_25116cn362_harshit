#include <iostream>
#include <string>
#include <unordered_map>

using namespace std;

char firstRepeatingChar(string s) {
    unordered_map<char, int> charCount;

   
    for (char c : s) {
        charCount[c]++;
    }

   
    for (char c : s) {
        if (charCount[c] > 1) {
            return c;
        }
    }

 
    return '\0'; 
}

int main() {
    string str = "swiss";
    char result = firstRepeatingChar(str);

    if (result != '\0') {
        cout << "The first repeating character is: '" << result << "'" << endl;
    } else {
        cout << "There are no repeating characters in the string." << endl;
    }

    return 0;
}
