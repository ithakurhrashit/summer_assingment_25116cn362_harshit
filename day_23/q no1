#include<iostream>
#include<bits/stdc++.h>
using namespace std  ;
int non_repeating_charecter(string s){
    int n = s.length();
    unordered_map<char,int> m ;
    queue<int> q;
    for(int i=0;i<n;i++){
        if(m.find(s[i])==m.end()){
            q.push(i);
           
        }
         m[s[i]]++;
        while(q.size()>0 && m[s[q.front()]]>1){
            q.pop();
        }
    }
    return q.empty() ? -1 : q.front();
}
int main(){
    string str;
    cout << " enter the  string : " << endl ;
    cin >> str ;
   cout << "the first non repeating charecter is at index :" <<  non_repeating_charecter(str);
    
}
