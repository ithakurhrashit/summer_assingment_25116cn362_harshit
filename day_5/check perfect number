// to check perfect number or not
#include<iostream>
using namespace std ;
 int main (){
    int n , a , remainder =0 ;
    cout << " enter the nmber you wanna check ";
    cin >> n ;
    a=n;
    for(int i =1;i<=n/2;i++){
        if(n%i==0){
            remainder=remainder+i;
        }

    }
    if (remainder==a){
        cout << " the given numb er is a perfect number";

    }
    else {
        cout << " the given number is not a perfect number";
    }

 }
