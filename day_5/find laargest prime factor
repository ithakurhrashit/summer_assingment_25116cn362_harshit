#include<iostream>
using namespace std ;
int checkprime (int n){
  int prime;
  for(int i=2;i<=n/2;i++){
    if(n%i==0){
           prime=-1;
    }
    else{
      prime=1;
    }
  }
  
}
int main(){
  int y ;
  cout << " enter the number ";
  cin >> y;
  for(int x=y-1;x>=2;x--){
    if(y%x==0){
      checkprime(x);
      if(prime=1){
        cout<<"largest prime factor ="<< x ;
        break ;
      }
      
    }
  }

}
