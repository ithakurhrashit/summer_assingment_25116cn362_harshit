// function to find maximum 
#include<iostream>
using namespace std ;
int max(int a , int b ){
    if(a>b){
        return a ;
    }
    else{
        return b ;
    }
}
int main (){
    int m,n ;
    cout << " enter the two numbers";
    cin >> m >> n ;
    cout << " maximum of them is" << max(m,n);

}
