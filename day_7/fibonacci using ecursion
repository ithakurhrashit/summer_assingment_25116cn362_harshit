// recursive fibonacci 
#include<iostream>
using namespace std ;
int fibonacci(int n){
    if(n<=1){
        return n ;
    }
    return fibonacci(n-1)+fibonacci(n-2);

}
int main (){
    int m ;
    cout << " enter the range you want to genereate fibonacci series";
    cin >> m ;
  for(int i=0;i<=m;i++){
    cout<< fibonacci(i);
  }
}
