// program to print matrix multiplication
#include<iostream>
using namespace std ;
int main(){
    int r1,r2,c1,c2;
    cout << "enter rows and columns of first matrix ";
    cin >> r1 >> c1;
    cout << "enter rows and colums of second matrix";
    cin >> r2 >> c2 ;
    if(c1!=r2){
        cout << "matrix multiplication not possible";
    }
    else {
        int a[r1][c1] , b[r2][c2] , m[r1][c2];
        cout << " enter the elements of first amtrix " ;
        for(int i=0;i<r1;i++){
            for(int j=0;j<c1;j++){
                cin >>a[i][j];
            }
        }
         cout << " enter the elements of second matrix  amtrix " ;
        for(int i=0;i<r2;i++){
            for(int j=0;j<c2;j++){
                cin >>b[i][j];
            }
        }
        for(int i=0;i<r1;i++){
            for(int j=0;j<c2;j++){
                m[i][j]=0;
                for(int k=0;k<c1 ;k++){
                    m[i][j]=m[i][j]+a[i][k]*b[k][j];
                }
            }
        }
        cout << "multiplied mattrix is " << endl ;
        for(int i=0;i<r1;i++){
            for(int j=0;j<c2;j++){
                cout << m[i][j] << " ";
            }
            cout << endl ;
        }
    }

}
