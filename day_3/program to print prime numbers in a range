// program to print prime numbes in a ranmge 
#include<iostream>
using namespace std ;
bool isprime(int n ){
  if(n<=1) return false;
  if(n==2) return true ;
  for(int i=2;i<=n/2;i++){
    if(n%i==0)  return false;
  }
  return true ;
}
int main(){
     int startrange,endrange ;
     cout << " enter the starting number";
     cin >> startrange ;
     cout << " enter the ending number";
     cin >> endrange ;
     while(startrange!=endrange){
      if(isprime(startrange)){
        cout << startrange << " ";
      }
      startrange++;
     }
}
