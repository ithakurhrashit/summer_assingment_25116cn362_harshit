// rihght rotate an array
#include<iostream>
using namespace std ;
int main(){
      int n ;
      cout << " enter the number of rows";
      cin >> n ;
      int a[n];
      cout << "enter the element of array ";
      for(int i=0;i<n;i++){
        cin >> a[i];
      }
      // now rotating right ;
      int b[n],k;
      cout << " enter the value by which you have to rotate ";
      cin >> k ;
      for(int i=0;i<n;i++){
        b[n+i-k]=a[i];
      }
      for(int i=0 ;i<n ;i++){
        cout << b[i];
      }
      cout << " array is rotated by right ";
}
