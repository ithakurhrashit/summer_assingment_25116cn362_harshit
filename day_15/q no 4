// wap to move zeros to the end 
#include<iostream>
using namespace std ;
int main (){
    int n ;
    cout << " enter the number of elements of arrya";
    cin >> n;
    int a[n];
    cout << " enter the elemenets";
    for(int i=0;i<n;i++){
        cin >> a[i];
    }
    // moving zeros to last 
    int nonzeroindex=0,temp ;
for(int i=0 ;i<n;i++){
    if(a[i]!=0){
            temp=a[i];
            a[i]=a[nonzeroindex];
            a[nonzeroindex]=temp;
            nonzeroindex++;
    }
}
cout << " array after moving zeros to end";
for(int i=0;i<n;i++){
    cout << a[i] << " ";
}
}
