// program for binary serch 
#include<iostream>
using namespace  std ;
int main(){
    int beg=0,mid,end ,n ;
    cout << "enter the size of array:";
    cin >> n ;
    int arr[n];
    cout << " enter the elements of array in sorted order :";
    for(int i=0;i<n;i++){
        cin >> arr[i];
    }
    cout << "enter the element to be serched :";
    int item ;
    cin >> item ;
    end =n-1;
    while(beg<=end){ 
    mid=(beg+end)/2;
    if(arr[mid]==item){
        cout << "element found at : "<< mid+1;
    }
    else if(arr[mid]<item){
        beg=mid+1;
    }
    else{
        end=mid-1;
    }
        if(beg>end){
            cout << "element not found in array";

        }
    }

}
