#include<iostream>
using namespace std ;
bool perfect(int n){
int sum =0;
for(int i=1;i<n;i++){
if(n%i==0){
sum=sum+i;}
if(sum==n){
return true ;}
else{return false;}
}
}
int main(){
int m;
cout <<"enter the number";
cin >> m ;
if(perfect(m)){
cout <<"number is a perfect number";
}
else{
cout << " number is not perfect number";
}
}
