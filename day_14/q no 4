//  find duplicates in an array 
#include<iostream>
using namespace std;
int main(){
    int n ;
    cout <<"enter the  number of elements of array";
    cin >> n ;
    int a[n],b[100],k=0;
    for(int i=0;i<n;i++){
        cout <<"enter "<<i<<"thelement of array";
        cin >>a[i];
    }
    for(int i=0;i<n;i++){
        for(int j=0;j<n-i;j++){
                 if(a[j]==a[j+1]){
                    a[j]=b[k];
                    k++;
                 }
                 
        }
    }
    cout << "duplicatee elements are";
    for(int i=0;i<=k;i++){
        cout << b[i];
    }
}
