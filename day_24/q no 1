#include <iostream>
#include <string>
using namespace std ;

bool areRotations( const string& str1, const string& str2) {
    // 1. If lengths are different or strings are empty, they can't be rotations
    if (str1.length() != str2.length() || str1.empty()) {
        return false;
    }

    // 2. Concatenate str1 with itself
   string concatenated = str1 + str1;

    // 3. Check if str2 is a substring of the concatenated string
    if (concatenated.find(str2) != string::npos) {
        return true;
    }

    return false;
}

int main() {
    string s1 = "waterbottle";
    string s2 = "erbottlewat";

    cout << "String 1: " << s1 << "\n";
    cout << "String 2: " << s2 << "\n\n";

    if (areRotations(s1, s2)) {
        cout << "Result: True (They are rotations of each other)" << std::endl;
    } else {
        cout << "Result: False (They are NOT rotations)" << std::endl;
    }

    return 0;
}
