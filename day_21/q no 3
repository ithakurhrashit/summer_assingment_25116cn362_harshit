// cont the number of vowels and consonants 
#include<iostream>
using namespace std ;
int main(){
    string str ;
    cout << "enter the string ";
    getline(cin,str);
    int vowels=0 , consonants =0;
    for(int i=0;str[i]!=0;i++){
        if(str[i]=='a' || str[i] == 'e' || str[i]=='i' || str[i]=='o'|| str[i]=='u' || str[i]=='A' || str[i] == 'E' || str[i]=='I' || str[i]=='O'|| str[i]=='U' ){
            vowels++;
        }
        else{
            consonants++;
        }
    }
    cout << "the number of vowels is : " << vowels << endl << "the no of consonants is :"<< consonants << endl ;
}
