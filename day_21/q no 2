// program to reverse a string 
#include<iostream>
using namespace std ;
int main(){
    string str ;
    cout << "enter the string " << endl ;
    getline(cin,str);
    string rev ;
    for(int i=str.length()-1;i>0;i--){
        rev = rev +str[i];
    }
    cout << "the reversed string is :" << rev << endl ;
}
