
#include <iostream>
using namespace std ;
int main(){
    int n , countodd=0,counteven=0;
    cout <<"enter the elements of array";
    cin >> n;
    int a[n];
    for(int i=0;i<n;i++){
     cout << "enter"<<i<<"th element of array;
     cin >> a[i];
    }
    for(int i=0; i<n ; i++){
        if(a[i]%2==0){
            counteven=counteven+1;
        }
        else{
            countodd=countodd+1;
        }
        
    }
    cout << "even number of elements are:counteven";
    cout <<"odd number of elements are:  countodd";
}
