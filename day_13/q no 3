// minimum and maximum element of arrray;
#include<iostream>
using namespace std ;
int main (){
    int n ;
    cout <<"enter the number of elements of array ";
    cin >> n;
    int a[n];
    cout <<"enter the elements of array";
    for(int i=0;i<n;i++){
        cin >> a[i];
    }
    int min =a[0];
    int max = a[0];
    for(int i=0;i,n;i++){
        if(a[i]>max){
            max=a[i];
        }
        if(a[i]<min){
            min=a[i];
        }
        }
        cout << "minimu element is : "<< min << endl <<"maximum element is "<< max ;
    }
