// WAP TO FIND PRODUCTS OF THE DIGITS 
#include<iostream>
using namespace std ;
int main(){
    int n , y , r , product=1;
    cout << "enter the number :";
    cin >> n ;
    y=n ;
    while(n>0){
        r=n%10;
        product=product*r;
        n=n/10;
    }
    cout << " the product of digits is :" << product << endl;
}
