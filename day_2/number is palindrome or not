// CHECKK WETHER THE NUMBER IS PALINDROME OR NOT 
#include<iostream>
using namespace std ;
int main(){
    int n , y , r, reverse=0 ;
    cout << "enter the number :";
    cin >> n ;
    y=n ;
    while(n>0){
        r=n%10;
        reverse = reverse*10+r;
        n=n/10;
    }
    if(y==reverse){
        cout << "the number is palindrome ";
    }
    else {
        cout << "the number is not palindrome";
    }
}
