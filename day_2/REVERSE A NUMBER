// WAP TO REVERSE A NUMBER 
#include<iostream>
using namespace std ;
int main (){
    int n , y  , r, reverse=0 ;
    cout << " enter the number :";
    cin >> n ;
    y=n ;
    while(n>0){
        r=n%10;
        reverse =reverse*10+r;
        n=n/10;


    }
    cout << " the reverse is :"<< reverse << endl ;
}
