#include <iostream>
using namespace std;

int main() {
    int n1, n2;
    cout << "Enter the number of elements for the first array: ";
    cin >> n1;
    int arr1[100]; 
    cout << "Enter the elements of the first array:\n";
    for(int i = 0; i < n1; i++) {
        cin >> arr1[i];
    }
    cout << "\nEnter the number of elements for the second array: ";
    cin >> n2;
    int arr2[100]; 
    cout << "Enter the elements of the second array:\n";
    for(int i = 0; i < n2; i++) {
        cin >> arr2[i];
    }
    int intersectionArr[100]; 
    int intersectionSize = 0;
    for(int i = 0; i < n1; i++) {
        bool foundInArr2 = false;
        for(int j = 0; j < n2; j++) {
            if(arr1[i] == arr2[j]) {
                foundInArr2 = true;
                break;
            }
        }
        if(foundInArr2) {
            bool isDuplicate = false;
            for(int k = 0; k < intersectionSize; k++) {
                if(arr1[i] == intersectionArr[k]) {
                    isDuplicate = true;
                    break;
                }
             
            }

            if(!isDuplicate) {
                intersectionArr[intersectionSize] = arr1[i];
                intersectionSize++;
            }
        }
    }
    cout << "\nThe Intersection of the two arrays is: ";
    if (intersectionSize == 0) {
        cout << "Empty (No common elements)";
    } else {
        for(int i = 0; i < intersectionSize; i++) {
            cout << intersectionArr[i] << " ";
        }
    }
    cout << endl;

    return 0;
}
