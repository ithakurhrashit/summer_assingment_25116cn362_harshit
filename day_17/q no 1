// write a program to merge arrays 
#include<iostream>
using namespace std ;
int main(){
    int n1,n2;
    cout <<"enter the size of first array";
    cin >> n1;
    cout << "enter the elements of array 1";
    int a[n1];
    for(int i=0;i<n1;i++){
        cin >> a[i];
    }
    cout << "enter the size of second array ";
    cin >> n2 ;
    int b[n2];
    cout << "enter the elements of second array ";
    for(int i=0;i<n2;i++){
        cin >> b[i];
    }
    int n3=n1+n2 ;
      int c[n3];
      cout << "merged array";
      for(int i=0;i<n1;i++){
        
            c[i]=a[i];
        }
    for(int i=n1 ;i<n3 ;i++){
        int j=0;
        c[i]=b[j];
        j++;
    }
    for(int i=0 ; i<n3 ;i++){
        cout << c[i] << " ";
    }
      
}
