#include <iostream>
using namespace std;

int main() {
    int n1, n2;
    cout << "Enter the number of elements for the first array: ";
    cin >> n1;
    int arr1[100]; 
    cout << "Enter the elements of the first array:\n";
    for(int i = 0; i < n1; i++) {
        cin >> arr1[i];
    }
    cout << "\nEnter the number of elements for the second array: ";
    cin >> n2;
    int arr2[100]; 
    cout << "Enter the elements of the second array:\n";
    for(int i = 0; i < n2; i++) {
        cin >> arr2[i];
    }
    int unionArr[200]; 
    int unionSize = 0;
    for(int i = 0; i < n1; i++) {
        bool isDuplicate = false;
        for(int j = 0; j < unionSize; j++) {
            if(arr1[i] == unionArr[j]) {
                isDuplicate = true;
                break;
            }
        }
        if(!isDuplicate) {
            unionArr[unionSize] = arr1[i];
            unionSize++;
        }
    }
    for(int i = 0; i < n2; i++) {
        bool isDuplicate = false;
        for(int j = 0; j < unionSize; j++) {
            if(arr2[i] == unionArr[j]) {
                isDuplicate = true;
                break;
            }
        }
        if(!isDuplicate) {
            unionArr[unionSize] = arr2[i];
            unionSize++;
        }
    }
    cout << "\nThe Union of the two arrays is: ";
    for(int i = 0; i < unionSize; i++) {
        cout << unionArr[i] << " ";
    }
    cout << endl;

    return 0;
}
